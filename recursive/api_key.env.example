OPENAI=xxxx

CLAUDE=xxx

SERPAPI=xxx

GEMINI=xxx

OPENROUTER=xxx

# Local Qwen inference
LOCAL_QWEN_MODEL_PATH=/path/to/your/qwen4b
LOCAL_QWEN_DEVICE=cuda:0
LOCAL_QWEN_ENABLE_THINKING=false
LOCAL_QWEN_MAX_INPUT_TOKENS=32768
# Optional. If LOCAL_QWEN_MAX_NEW_TOKENS is unset, generation uses the
# remaining context window after the prompt.
LOCAL_QWEN_MAX_TOTAL_TOKENS=40960
# LOCAL_QWEN_MAX_NEW_TOKENS=8192
